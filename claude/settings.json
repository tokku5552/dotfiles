{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "deny": [
      "Bash(git config --global *)",
      "Bash(brew install *)",
      "Bash(npm install -g *)",
      "Bash(chmod 777 *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(gh repo delete *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(gh pr merge *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/scripts/deny-check.sh"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/scripts/audit-log.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": false,
    "skill-creator@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "asdd-kit@asdd-kit": true,
    "codex@openai-codex": true,
    "linear-kit@my-private-cc-plugins": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "my-private-cc-plugins": {
      "source": {
        "source": "github",
        "repo": "tokku5552/cc-plugins"
      },
      "autoUpdate": true
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux"
}

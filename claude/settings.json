{
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "example-skills@anthropic-agent-skills": false,
    "skill-creator@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Bash(git config --global *)",
      "Bash(brew install *)",
      "Bash(npm install -g *)",
      "Bash(chmod 777 *)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(gh repo delete *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh ~/.claude/scripts/deny-check.sh"
          }
        ]
      }
    ]
  }
}
